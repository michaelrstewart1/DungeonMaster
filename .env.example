# AI Dungeon Master

## Environment Variables
# Copy to .env and fill in your values

# Database
DM_DATABASE_URL=postgresql+asyncpg://dungeonmaster:dungeonmaster@localhost:5432/dungeonmaster
DM_DATABASE_ECHO=false

# MongoDB (SRD data)
DM_MONGODB_URL=mongodb://localhost:27017
DM_MONGODB_DATABASE=5e-database

# Redis
DM_REDIS_URL=redis://localhost:6379/0

# LLM Provider: anthropic, openai, or ollama
DM_LLM_PROVIDER=anthropic
DM_ANTHROPIC_API_KEY=
DM_OPENAI_API_KEY=
DM_OLLAMA_BASE_URL=http://localhost:11434
DM_OLLAMA_MODEL=llama3.1:8b

# Voice (disabled by default)
DM_VOICE_ENABLED=false
DM_STT_MODEL=base.en
DM_TTS_ENGINE=piper

# Debug mode
DM_DEBUG=false

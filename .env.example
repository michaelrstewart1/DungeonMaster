# AI Dungeon Master — Configuration
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════
# Database
# ═══════════════════════════════════════
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://dm:changeme@localhost:5432/dungeon_master
DM_DATABASE_ECHO=false

# MongoDB (SRD reference data)
MONGODB_URL=mongodb://localhost:27017/srd

# Redis (cache, queues, streaming)
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════
# LLM Provider
# ═══════════════════════════════════════
# Options: anthropic, openai, ollama
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b

# Cloud API keys (only needed for cloud providers)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434

# ═══════════════════════════════════════
# Voice I/O
# ═══════════════════════════════════════
# STT: whisper (GPU/CPU) 
STT_PROVIDER=whisper
STT_DEVICE=cpu
WHISPER_MODEL_SIZE=base

# TTS: piper (CPU) or coqui (GPU) or openai (cloud — wizard voice)
TTS_PROVIDER=openai
TTS_DEVICE=cpu

# OpenAI TTS voice settings (wizard/sage voice for the AI DM)
# Voice options: onyx (deep/gravelly, best for DM), echo, alloy, fable, nova, shimmer
DM_OPENAI_TTS_VOICE=onyx
DM_OPENAI_TTS_MODEL=tts-1-hd

# ═══════════════════════════════════════
# GPU (for docker-compose.gpu.yml)
# ═══════════════════════════════════════
# AMD ROCm: HSA_OVERRIDE_GFX_VERSION maps to your GPU arch
#   RX 6600/6650/6700/6800/6900 (RDNA2) = 10.3.0
#   RX 7600/7700/7800/7900 (RDNA3) = 11.0.0
HSA_OVERRIDE_GFX_VERSION=10.3.0

# ═══════════════════════════════════════
# Ports
# ═══════════════════════════════════════
FRONTEND_PORT=3000
BACKEND_PORT=8000

# ═══════════════════════════════════════
# Debug
# ═══════════════════════════════════════
DM_DEBUG=false

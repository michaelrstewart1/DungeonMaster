# AI Dungeon Master — Configuration
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════
# Database
# ═══════════════════════════════════════
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://dm:changeme@localhost:5432/dungeon_master
DM_DATABASE_ECHO=false

# MongoDB (SRD reference data)
MONGODB_URL=mongodb://localhost:27017/srd

# Redis (cache, queues, streaming)
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════
# LLM Provider
# ═══════════════════════════════════════
# Options: anthropic, openai, ollama
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b

# Cloud API keys (only needed for cloud providers)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434

# ═══════════════════════════════════════
# Voice I/O
# ═══════════════════════════════════════
# STT: whisper (GPU/CPU) 
STT_PROVIDER=whisper
STT_DEVICE=cpu
WHISPER_MODEL_SIZE=base

# TTS: piper (CPU) or coqui (GPU)
TTS_PROVIDER=piper
TTS_DEVICE=cpu

# ═══════════════════════════════════════
# Ports
# ═══════════════════════════════════════
FRONTEND_PORT=3000
BACKEND_PORT=8000

# ═══════════════════════════════════════
# Debug
# ═══════════════════════════════════════
DM_DEBUG=false
